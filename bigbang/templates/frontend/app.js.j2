// Generated by BIG BANG — {{ universe.name }}
const API = '/api/v1';

// ── UI helpers ────────────────────────────────────────────────────────────────

let _toastTimer;
function toast(msg, type = 'success') {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className = `toast show ${type}`;
  clearTimeout(_toastTimer);
  _toastTimer = setTimeout(() => { el.className = 'toast'; }, 3500);
}

function showSection(id) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(a => a.classList.remove('active'));
  const panel = document.getElementById(id);
  if (panel) panel.classList.add('active');
  const link = document.querySelector(`.nav-item[href="#${id}"]`);
  if (link) link.classList.add('active');
}

async function apiFetch(url, options = {}) {
  const res = await fetch(url, {
    headers: { 'Content-Type': 'application/json' },
    ...options,
  });
  if (!res.ok) {
    const err = await res.json().catch(() => ({}));
    throw new Error(err.detail || `HTTP ${res.status}`);
  }
  return res.status === 204 ? null : res.json();
}

async function createEntity(event, endpoint, reloadFn) {
  event.preventDefault();
  const form = event.target;
  const raw = Object.fromEntries(new FormData(form));
  // Coerce checkbox → boolean, number inputs → numbers
  const data = {};
  Array.from(form.elements).forEach(el => {
    if (!el.name) return;
    if (el.type === 'checkbox') data[el.name] = el.checked;
    else if (el.type === 'number') data[el.name] = el.value === '' ? undefined : Number(el.value);
    else data[el.name] = el.value || undefined;
  });
  try {
    await apiFetch(`${API}/${endpoint}`, { method: 'POST', body: JSON.stringify(data) });
    toast(`Created!`);
    form.reset();
    reloadFn();
  } catch (e) {
    toast(e.message, 'error');
  }
}

async function deleteItem(endpoint, id, reloadFn) {
  try {
    await apiFetch(`${API}/${endpoint}/${id}`, { method: 'DELETE' });
    toast('Deleted.', 'info');
    reloadFn();
  } catch (e) {
    toast(e.message, 'error');
  }
}

function renderCard(item, fields, endpoint, reloadFn) {
  const rows = fields.map(f =>
    `<div class="card-row"><span class="card-key">${f}</span><span class="card-val">${item[f] ?? '—'}</span></div>`
  ).join('');
  return `
    <div class="card">
      ${rows}
      <div class="card-footer">
        <span class="card-id">#${item.id}</span>
        <button class="btn-danger-sm" onclick="deleteItem('${endpoint}', ${item.id}, ${reloadFn.name})">Delete</button>
      </div>
    </div>`;
}

// ── Entity loaders ────────────────────────────────────────────────────────────

{% for entity in universe.entities %}
async function load{{ entity.name }}s() {
  try {
    const items = await apiFetch(`${API}/{{ entity.name | plural }}`);
    const grid = document.getElementById('{{ entity.name | lower }}s-grid');
    if (!items.length) {
      grid.innerHTML = '<p class="empty">No {{ entity.name | lower }}s yet. Create one above.</p>';
      return;
    }
    const fields = [{% for f in entity.fields %}'{{ f.name }}'{% if not loop.last %}, {% endif %}{% endfor %}];
    grid.innerHTML = items.map(item => renderCard(item, fields, '{{ entity.name | plural }}', load{{ entity.name }}s)).join('');
  } catch (e) {
    toast(e.message, 'error');
  }
}

{% endfor %}

// ── Flow execution ────────────────────────────────────────────────────────────

{% if universe.flows %}
async function executeFlow(name) {
  try {
    const result = await apiFetch(`${API}/flows/${name}`, { method: 'POST' });
    toast(`Flow "${result.flow}" — ${result.steps.length} steps completed.`);
    console.log('Flow result:', result);
  } catch (e) {
    toast(e.message, 'error');
  }
}
{% endif %}

// ── Monetization ──────────────────────────────────────────────────────────────

{% if universe.monetization %}
async function subscribe(planName) {
  try {
    const data = await apiFetch(`${API}/subscribe/${planName}`, { method: 'POST' });
    if (data.url) {
      window.location.href = data.url;
    } else {
      toast(`Plan "${planName}" selected. Wire up Stripe to activate.`, 'info');
    }
  } catch (e) {
    toast(e.message, 'error');
  }
}
{% endif %}

// ── Init ──────────────────────────────────────────────────────────────────────

document.addEventListener('DOMContentLoaded', () => {
  const firstPanel = document.querySelector('.panel');
  if (firstPanel) showSection(firstPanel.id);

{% for entity in universe.entities %}
  load{{ entity.name }}s();
{% endfor %}
});
