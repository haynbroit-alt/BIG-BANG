# Generated by BIG BANG — {{ universe.name }}
# cp .env.example .env  then fill in your secrets

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, zero config)
DATABASE_URL=sqlite:///./{{ name_slug }}.db

# PostgreSQL (uncomment when scaling)
# DATABASE_URL=postgresql://bigbang:singularity@db:5432/{{ name_slug }}_db
# DB_PASSWORD=change_me_in_production
{% if universe.auth.enabled %}

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-generate-a-real-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
{% endif %}
{% if universe.monetization %}

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLIC_KEY=pk_test_...
{% endif %}
