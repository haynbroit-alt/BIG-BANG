# Generated by BIG BANG — Universe: {{ universe.name }}
from typing import List

from fastapi import APIRouter, Depends, HTTPException
from sqlalchemy.orm import Session

from database import get_db
import models
import schemas

router = APIRouter()

{% for entity in universe.entities %}
# ── {{ entity.name }} CRUD ─────────────────────────────────────────────────────

@router.get("/{{ entity.name | plural }}", response_model=List[schemas.{{ entity.name }}Response], tags=["{{ entity.name }}"])
def list_{{ entity.name | slug }}s(skip: int = 0, limit: int = 100, db: Session = Depends(get_db)):
    return db.query(models.{{ entity.name }}).offset(skip).limit(limit).all()


@router.post("/{{ entity.name | plural }}", response_model=schemas.{{ entity.name }}Response, status_code=201, tags=["{{ entity.name }}"])
def create_{{ entity.name | slug }}(payload: schemas.{{ entity.name }}Create, db: Session = Depends(get_db)):
    item = models.{{ entity.name }}(**payload.model_dump(exclude_unset=True))
    db.add(item)
    db.commit()
    db.refresh(item)
    return item


@router.get("/{{ entity.name | plural }}/{item_id}", response_model=schemas.{{ entity.name }}Response, tags=["{{ entity.name }}"])
def get_{{ entity.name | slug }}(item_id: int, db: Session = Depends(get_db)):
    item = db.query(models.{{ entity.name }}).filter(models.{{ entity.name }}.id == item_id).first()
    if not item:
        raise HTTPException(status_code=404, detail="{{ entity.name }} not found")
    return item


@router.put("/{{ entity.name | plural }}/{item_id}", response_model=schemas.{{ entity.name }}Response, tags=["{{ entity.name }}"])
def update_{{ entity.name | slug }}(item_id: int, payload: schemas.{{ entity.name }}Create, db: Session = Depends(get_db)):
    item = db.query(models.{{ entity.name }}).filter(models.{{ entity.name }}.id == item_id).first()
    if not item:
        raise HTTPException(status_code=404, detail="{{ entity.name }} not found")
    for key, value in payload.model_dump(exclude_unset=True).items():
        setattr(item, key, value)
    db.commit()
    db.refresh(item)
    return item


@router.delete("/{{ entity.name | plural }}/{item_id}", status_code=204, tags=["{{ entity.name }}"])
def delete_{{ entity.name | slug }}(item_id: int, db: Session = Depends(get_db)):
    item = db.query(models.{{ entity.name }}).filter(models.{{ entity.name }}.id == item_id).first()
    if not item:
        raise HTTPException(status_code=404, detail="{{ entity.name }} not found")
    db.delete(item)
    db.commit()

{% endfor %}
{% if universe.flows %}
# ── Flows / Workflows ─────────────────────────────────────────────────────────

{% for flow in universe.flows %}
@router.post("/flows/{{ flow.name }}", response_model=schemas.FlowResult, tags=["flows"])
def execute_{{ flow.name | slug }}(db: Session = Depends(get_db)):
    """Trigger: {{ flow.trigger }}"""
    steps = []
{% for step in flow.steps %}
    steps.append({"action": "{{ step.action }}", "status": "executed"})
{% endfor %}
    return schemas.FlowResult(
        flow="{{ flow.name }}",
        trigger="{{ flow.trigger }}",
        steps=steps,
    )

{% endfor %}
{% endif %}
{% if universe.monetization %}
# ── Monetization ──────────────────────────────────────────────────────────────

_PLANS = {
{% for plan in universe.monetization.plans %}
    "{{ plan.name }}": {"price": {{ plan.price }}, "currency": "{{ plan.currency }}"},
{% endfor %}
}


@router.get("/plans", tags=["monetization"])
def list_plans():
    return {"model": "{{ universe.monetization.model }}", "plans": _PLANS}


@router.post("/subscribe/{plan_name}", tags=["monetization"])
def subscribe(plan_name: str):
    """Create a Stripe Checkout session for the given plan."""
    if plan_name not in _PLANS:
        raise HTTPException(status_code=404, detail=f"Plan '{plan_name}' not found")
    plan = _PLANS[plan_name]
    # Wire up Stripe here:
    #   import stripe, os
    #   stripe.api_key = os.environ["STRIPE_SECRET_KEY"]
    #   session = stripe.checkout.Session.create(...)
    #   return {"url": session.url}
    return {
        "message": f"Configure STRIPE_SECRET_KEY to activate payments.",
        "plan": plan_name,
        "price": plan["price"],
        "currency": plan["currency"],
    }
{% endif %}
