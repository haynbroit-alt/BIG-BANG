# Generated by BIG BANG — Ledger API for {{ universe.name }}
from fastapi import APIRouter, HTTPException
from pydantic import BaseModel
from typing import Optional

from ledger import get_public_key_hex, read_ledger, sign_event, verify_proof

router = APIRouter(prefix="/ledger", tags=["ledger"])


class ProofRequest(BaseModel):
    action: str
    entity: str
    entity_id: str
    payload: Optional[dict] = None
    actor: Optional[str] = None


@router.post("/sign", summary="Sign an action and record it in the ledger")
def sign(req: ProofRequest):
    """Create a cryptographic proof for any action."""
    return sign_event(
        action=req.action,
        entity=req.entity,
        entity_id=req.entity_id,
        payload=req.payload,
        actor=req.actor,
    )


@router.post("/verify", summary="Verify a proof's Ed25519 signature")
def verify(proof: dict):
    """Verify that a proof was signed by this universe's key."""
    valid = verify_proof(proof)
    if not valid:
        raise HTTPException(status_code=400, detail="Invalid or tampered proof")
    return {"valid": True}


@router.get("/entries", summary="Read ledger entries")
def list_entries(limit: int = 50, offset: int = 0):
    return {"entries": read_ledger(limit=limit, offset=offset)}


@router.get("/public-key", summary="Get the universe's Ed25519 public key")
def public_key():
    return {"public_key": get_public_key_hex(), "algorithm": "Ed25519"}
