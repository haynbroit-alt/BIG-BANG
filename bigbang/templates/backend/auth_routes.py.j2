@router.post("/register", response_model=auth_schemas.UserResponse, status_code=201)
def register(payload: auth_schemas.UserCreate, db: Session = Depends(get_db)):
    """Create a new account."""
    if db.query(auth_models.User).filter(auth_models.User.email == payload.email).first():
        raise HTTPException(status_code=400, detail="Email already registered")
    user = auth_models.User(
        id=str(uuid.uuid4()),
        email=payload.email,
        hashed_password=_hash_password(payload.password),
