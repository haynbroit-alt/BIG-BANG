@router.post("/login", response_model=auth_schemas.Token)
def login(form: OAuth2PasswordRequestForm = Depends(), db: Session = Depends(get_db)):
    """Exchange email + password for a Bearer token."""
    user = db.query(auth_models.User).filter(auth_models.User.email == form.username).first()
    if not user or not _verify_password(form.password, user.hashed_password):
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="Incorrect email or password",
        )
    return auth_schemas.Token(access_token=_create_token(user.id))


@router.get("/me", response_model=auth_schemas.UserResponse)
def get_me(current_user: auth_models.User = Depends(get_current_user)):
    """Return the authenticated user's profile."""
    return current_user


@router.post("/logout")
def logout():
    """Client-side: discard the token. No server-side state to invalidate."""
    return {"message": "Logged out — discard your token on the client."}
