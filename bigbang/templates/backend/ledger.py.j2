# Generated by BIG BANG — Proof Ledger for {{ universe.name }}
# Ed25519 cryptographic proof system — every action is signed and timestamped.
import hashlib
import json
import os
from datetime import datetime, timezone
from pathlib import Path
from typing import Optional

from cryptography.hazmat.primitives.asymmetric.ed25519 import (
    Ed25519PrivateKey,
    Ed25519PublicKey,
)
from cryptography.hazmat.primitives import serialization
from cryptography.exceptions import InvalidSignature

_LEDGER_FILE = Path(os.getenv("LEDGER_PATH", "./{{ universe.name_slug }}.ledger.jsonl"))
_KEY_FILE    = Path(os.getenv("LEDGER_KEY_PATH", "./{{ universe.name_slug }}.key"))


# ── Key management ────────────────────────────────────────────────────────────

def _load_or_create_key() -> Ed25519PrivateKey:
    if _KEY_FILE.exists():
        pem = _KEY_FILE.read_bytes()
        return serialization.load_pem_private_key(pem, password=None)
    key = Ed25519PrivateKey.generate()
    _KEY_FILE.write_bytes(
        key.private_bytes(
            serialization.Encoding.PEM,
            serialization.PrivateFormat.PKCS8,
            serialization.NoEncryption(),
        )
    )
    return key


_private_key: Ed25519PrivateKey = _load_or_create_key()
_public_key: Ed25519PublicKey   = _private_key.public_key()


def get_public_key_hex() -> str:
    raw = _public_key.public_bytes(serialization.Encoding.Raw, serialization.PublicFormat.Raw)
    return raw.hex()


# ── Proof creation ────────────────────────────────────────────────────────────

def sign_event(
    action: str,
    entity: str,
    entity_id: int | str,
    payload: Optional[dict] = None,
    actor: Optional[str] = None,
) -> dict:
    """
    Create a signed proof for an action.
    Records it in the ledger and returns the proof object.
    """
    proof = {
        "action":    action,
        "entity":    entity,
        "entity_id": str(entity_id),
        "actor":     actor or "system",
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "payload":   payload or {},
    }

    canonical = json.dumps(proof, sort_keys=True, separators=(",", ":")).encode()
    proof["hash"]      = hashlib.sha256(canonical).hexdigest()
    proof["signature"] = _private_key.sign(canonical).hex()
    proof["public_key"] = get_public_key_hex()

    _append_to_ledger(proof)
    return proof


def verify_proof(proof: dict) -> bool:
    """Verify that a proof's signature is valid."""
    try:
        check = {k: v for k, v in proof.items() if k not in ("hash", "signature", "public_key")}
        canonical = json.dumps(check, sort_keys=True, separators=(",", ":")).encode()

        pub_bytes = bytes.fromhex(proof["public_key"])
        pub_key = Ed25519PublicKey.from_public_bytes(pub_bytes)
        pub_key.verify(bytes.fromhex(proof["signature"]), canonical)
        return True
    except (InvalidSignature, Exception):
        return False


# ── Ledger storage ────────────────────────────────────────────────────────────

def _append_to_ledger(proof: dict) -> None:
    _LEDGER_FILE.parent.mkdir(parents=True, exist_ok=True)
    with _LEDGER_FILE.open("a", encoding="utf-8") as f:
        f.write(json.dumps(proof) + "\n")


def read_ledger(limit: int = 100, offset: int = 0) -> list[dict]:
    if not _LEDGER_FILE.exists():
        return []
    with _LEDGER_FILE.open("r", encoding="utf-8") as f:
        lines = f.readlines()
    entries = [json.loads(ln) for ln in lines if ln.strip()]
    return entries[offset: offset + limit]
